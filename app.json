{
  "expo": {
    "name": "Fastra",
    "slug": "entrack",
    "version": "1.2.0",
    "orientation": "default",
    "icon": "./assets/images/icon.png",
    "scheme": "fastra",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "allowBackup": false,
      "adaptiveIcon": {
        "backgroundColor": "#171717",
        "foregroundImage": "./assets/images/icon-foreground.png",
        "backgroundImage": "./assets/images/icon-background.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.saleraf.fastra",
      "googleServicesFile": "./google-services.json",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "entrack-fardss.firebaseapp.com",
              "pathPrefix": "/__/auth/action"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      "./plugins/withAndroidNotificationListener",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-image.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#171717"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "801721a5-6019-4082-b09f-99b109dee6bd"
      }
    },
    "owner": "fardss"
  }
}
